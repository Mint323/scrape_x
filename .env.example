# =============================================================================
# X Scraper Service Configuration
# =============================================================================

# ───── Required: Apify (for tweets / followers / following) ─────
# Get from https://console.apify.com/settings/integrations
APIFY_API_TOKEN=

# ───── Required: scrape.do (for profile via x.com proxy) ─────
SCRAPE_DO_TOKEN=

# ───── Required: MongoDB (for jobs, results, cache, distributed lock) ─────
MONGODB_URI=mongodb://127.0.0.1:27017/
MONGODB_DATABASE=x_scraper
# Cache TTL for profile data (seconds, default 1 hour)
PROFILE_CACHE_TTL=3600

# ───── Server ─────
# Optional: Bearer token for MCP/REST auth (leave empty to disable auth)
X_SCRAPER_API_KEY=
# Per-tool timeout in seconds (default 300)
X_SCRAPER_TOOL_TIMEOUT=300

# ───── Profile scraping ─────
# scrape.do request timeout (seconds, default 30)
REQUEST_TIMEOUT=30
# Default concurrency when not specified (default 50)
SCRAPE_CONCURRENCY=50
# When usernames count > threshold, auto switch to async job (default 50)
ASYNC_JOB_THRESHOLD=50

# ───── Job engine ─────
# Bulk write batch size to MongoDB (default 50)
JOB_BULK_FLUSH_SIZE=50
# Max seconds to wait before flushing partial batch (default 5)
JOB_BULK_FLUSH_INTERVAL=5
# Heartbeat interval for job ownership (default 15s)
JOB_HEARTBEAT_INTERVAL=15
# Mark a job as orphan if no heartbeat for this long (default 60s)
JOB_HEARTBEAT_TIMEOUT=60
# Orphan claimer scan interval (default 30s)
ORPHAN_SCAN_INTERVAL=30

# ───── Adaptive concurrency tuning ─────
# Time window for measuring 429 ratio (seconds, default 30)
ADAPTIVE_WINDOW_SECONDS=30
# 429 ratio threshold to halve concurrency (default 0.1 = 10%)
ADAPTIVE_429_THRESHOLD=0.1
# Growth multiplier when 0% 429s in a window (default 1.2)
ADAPTIVE_GROWTH_FACTOR=1.2

# ───── Apify retry ─────
# Max retry attempts per Apify call (default 3)
APIFY_MAX_RETRIES=3
# Exponential backoff base in seconds (default 2.0)
APIFY_RETRY_BASE=2.0
